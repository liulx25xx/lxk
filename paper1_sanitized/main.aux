\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Framework overview.} Agent failures produce four distinct cascade patterns. Cascade structure predicts whether behavioral scaffolding can help: repetitive loops (\textsc  {Edit}) and commitment spirals (\textsc  {Plan}) respond strongly; reasoning drift (\textsc  {Logic}) does not. Applying the wrong strategy to the wrong type (\textsc  {Loc} with test-guided) is worse than no intervention. The two principles together imply that agent recovery is fundamentally a diagnostic problem.\relax }}{3}{figure.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:framework}{{1}{3}{\textbf {Framework overview.} Agent failures produce four distinct cascade patterns. Cascade structure predicts whether behavioral scaffolding can help: repetitive loops (\textsc {Edit}) and commitment spirals (\textsc {Plan}) respond strongly; reasoning drift (\textsc {Logic}) does not. Applying the wrong strategy to the wrong type (\textsc {Loc} with test-guided) is worse than no intervention. The two principles together imply that agent recovery is fundamentally a diagnostic problem.\relax }{figure.caption.3}{}}
