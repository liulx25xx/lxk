\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Position-swap consistency under matched unbalanced and balanced data constructions. Coral circles and blue diamonds show the two conditions; connecting segments isolate the data intervention within each training objective. The dashed line is the untrained baseline. GRPO-A and GRPO-F denote accuracy-only and full-composite GRPO.}}{6}{figure.caption.8}\protected@file@percent }
\newlabel{fig:fix}{{3}{6}{Position-swap consistency under matched unbalanced and balanced data constructions. Coral circles and blue diamonds show the two conditions; connecting segments isolate the data intervention within each training objective. The dashed line is the untrained baseline. GRPO-A and GRPO-F denote accuracy-only and full-composite GRPO}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Cross-model GRPO replication. Unbalanced training reduces consistency most strongly on Mistral and Qwen2.5, while balanced data restores or improves consistency across all three tested model families. Exact accuracy values and full controls are in \mbox  {Appendix Table~\ref {tab:crossmodel}}.}}{6}{figure.caption.9}\protected@file@percent }
\newlabel{fig:crossmodel-main}{{4}{6}{Cross-model GRPO replication. Unbalanced training reduces consistency most strongly on Mistral and Qwen2.5, while balanced data restores or improves consistency across all three tested model families. Exact accuracy values and full controls are in \mbox {Appendix Table~\ref {tab:crossmodel}}}{figure.caption.9}{}}
