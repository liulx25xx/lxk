\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces GRPO learning rate sweep on Medicine (2-seed avg for lr=2e-5). The standard recipe (5e-7) slightly degrades performance. Raising the rate 40$\times $ to 2e-5 produces +7.4\% improvement, far outperforming the best SFT result (59.5\%). At 1e-4, training collapses.\relax }}{5}{table.caption.4}\protected@file@percent }
\newlabel{tab:lr_sweep}{{3}{5}{GRPO learning rate sweep on Medicine (2-seed avg for lr=2e-5). The standard recipe (5e-7) slightly degrades performance. Raising the rate 40$\times $ to 2e-5 produces +7.4\% improvement, far outperforming the best SFT result (59.5\%). At 1e-4, training collapses.\relax }{table.caption.4}{}}
