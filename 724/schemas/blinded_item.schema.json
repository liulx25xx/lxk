{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blinded parser-audit item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "annotation_id",
    "question",
    "options",
    "prediction",
    "manual_answer",
    "status",
    "notes"
  ],
  "properties": {
    "annotation_id": {"type": "string", "minLength": 1},
    "question": {"type": "string", "minLength": 1},
    "options": {
      "type": "object",
      "minProperties": 2,
      "maxProperties": 5,
      "additionalProperties": false,
      "properties": {
        "A": {"type": "string", "minLength": 1},
        "B": {"type": "string", "minLength": 1},
        "C": {"type": "string", "minLength": 1},
        "D": {"type": "string", "minLength": 1},
        "E": {"type": "string", "minLength": 1}
      },
      "required": ["A", "B", "C", "D"]
    },
    "prediction": {"type": "string"},
    "manual_answer": {"type": "null"},
    "status": {"type": "null"},
    "notes": {"const": ""}
  }
}
